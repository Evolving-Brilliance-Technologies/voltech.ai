{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:landing": "APP_TARGET=landing vite --port 3000",
    "dev:impactmaker": "APP_TARGET=impactmaker vite --port 3001",
    "dev:changemaker": "APP_TARGET=changemaker vite --port 3002",
    "dev:verifier": "APP_TARGET=verifier vite --port 3003",
    "dev:gov": "APP_TARGET=gov vite --port 3004",
    "dev:partner": "APP_TARGET=partner vite --port 3005",
    "dev:admin": "APP_TARGET=admin vite --port 3006",
    "dev:all": "concurrently -k -p \"[{name}]\" -n \"LANDING,IMPACT,CHANGE,VERIFY,GOV,PARTNER,ADMIN\" -c \"bgBlue.bold,bgGreen.bold,bgMagenta.bold,bgCyan.bold,bgYellow.bold,bgRed.bold,bgWhite.bold\" \"bun:dev:landing\" \"bun:dev:impactmaker\" \"bun:dev:changemaker\" \"bun:dev:verifier\" \"bun:dev:gov\" \"bun:dev:partner\" \"bun:dev:admin\"",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:landing": "APP_TARGET=landing vite build --outDir dist/landing",
    "build:impactmaker": "APP_TARGET=impactmaker vite build --outDir dist/impactmaker",
    "build:changemaker": "APP_TARGET=changemaker vite build --outDir dist/changemaker",
    "build:verifier": "APP_TARGET=verifier vite build --outDir dist/verifier",
    "build:gov": "APP_TARGET=gov vite build --outDir dist/gov",
    "build:partner": "APP_TARGET=partner vite build --outDir dist/partner",
    "build:admin": "APP_TARGET=admin vite build --outDir dist/admin",
    "build:all": "tsc -p tsconfig.build.json && concurrently \"bun:build:landing\" \"bun:build:impactmaker\" \"bun:build:changemaker\" \"bun:build:verifier\" \"bun:build:gov\" \"bun:build:partner\" \"bun:build:admin\"",
    "preview:landing": "vite preview --outDir dist/landing --port 3000",
    "preview:impactmaker": "vite preview --outDir dist/impactmaker --port 3001",
    "preview:changemaker": "vite preview --outDir dist/changemaker --port 3002",
    "preview:verifier": "vite preview --outDir dist/verifier --port 3003",
    "preview:gov": "vite preview --outDir dist/gov --port 3004",
    "preview:partner": "vite preview --outDir dist/partner --port 3005",
    "preview:admin": "vite preview --outDir dist/admin --port 3006",
    "preview:all": "concurrently -k -p \"[{name}]\" -n \"LANDING,IMPACT,CHANGE,VERIFY,GOV,PARTNER,ADMIN\" \"bun:preview:landing\" \"bun:preview:impactmaker\" \"bun:preview:changemaker\" \"bun:preview:verifier\" \"bun:preview:gov\" \"bun:preview:partner\" \"bun:preview:admin\"",
    "tsc": "tsc -p tsconfig.json",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "format:fix": "biome check --write .",
    "imports:sort": "biome check --write --unsafe .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "generate-client": "openapi-ts",
    "test": "bunx playwright test",
    "test:ui": "bunx playwright test --ui"
  },
  "dependencies": {
    "@hey-api/client-axios": "^0.9.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.19",
    "axios": "1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "form-data": "4.0.5",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@hey-api/openapi-ts": "^0.93.1",
    "@playwright/test": "1.58.2",
    "@tanstack/router-devtools": "^1.163.3",
    "@tanstack/router-plugin": "^1.164.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "dotenv": "^17.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "overrides": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
