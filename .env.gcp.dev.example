# =============================================================================
# GCP DEV Environment Reference — voltech.ai
# =============================================================================
# This file documents the environment variables and secrets needed when the
# app runs on GCP Cloud Run (dev environment).
#
# ❌ Do NOT commit real values. Secrets go in Google Secret Manager.
# =============================================================================

# ── GCP Infra ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=voltechai
GCP_REGION=asia-southeast1

# ── Cloud Run Service Names ───────────────────────────────────────────────────
BACKEND_SERVICE=dev-backend
LANDING_SERVICE=dev-landing
IMPACTMAKER_SERVICE=dev-impactmaker
CHANGEMAKER_SERVICE=dev-changemaker
VERIFIER_SERVICE=dev-verifier
GOV_SERVICE=dev-gov
PARTNER_SERVICE=dev-partner
ADMIN_SERVICE=dev-admin

# ── Artifact Registry ─────────────────────────────────────────────────────────
# Images are pushed to:
#   asia-southeast1-docker.pkg.dev/voltechai/app-services-dev/<image>:<sha>

# ── Cloud SQL ─────────────────────────────────────────────────────────────────
# Instance connection name (used by Cloud Run --add-cloudsql-instances):
CLOUD_SQL_CONNECTION_NAME=voltechai:asia-southeast1:voltech-sql-dev-<SUFFIX>
POSTGRES_DB=app_dev
POSTGRES_USER=postgres
# Secret: dev-postgres-password  (managed in Secret Manager — do not put here)

# ── Cloud Storage (GCS) ──────────────────────────────────────────────────────
# Bucket name:
BUCKET_NAME=voltech-storage-dev-<SUFFIX>
#
# ✅ No storage credentials needed on Cloud Run!
#    The backend service account (backend-sa-dev@voltechai.iam.gserviceaccount.com)
#    has roles/storage.objectAdmin on the bucket, and Cloud Run automatically
#    injects these credentials via Application Default Credentials (ADC).
#    The backend just needs the bucket name via MINIO_BUCKET_NAME.
#
# MinIO credentials (MINIO_ROOT_USER / MINIO_ROOT_PASSWORD) are only used
# for local development (docker compose) or VM deployments with self-hosted MinIO.

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
PROJECT_NAME=voltech.ai
# Secret: dev-secret-key              (JWT signing key — generate with: openssl rand -hex 32)
# Secret: dev-first-superuser-password

FIRST_SUPERUSER=admin@voltech.ai

# ── URLs (where each service is hosted) ──────────────────────────────────────
VITE_API_URL=https://api.dev.voltech.demoebt.com
BACKEND_URL=https://api.dev.voltech.demoebt.com
LANDING_URL=https://dev.voltech.demoebt.com
IMPACTMAKER_URL=https://impactmaker.dev.voltech.demoebt.com
CHANGEMAKER_URL=https://changemaker.dev.voltech.demoebt.com
VERIFIER_URL=https://verifier.dev.voltech.demoebt.com
GOV_URL=https://gov.dev.voltech.demoebt.com
PARTNER_URL=https://partner.dev.voltech.demoebt.com
ADMIN_URL=https://admin.dev.voltech.demoebt.com

# ── Email (Brevo / SendGrid / etc.) ──────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_TLS=true
EMAILS_FROM_EMAIL=noreply@voltech.demoebt.com
# Secret: dev-smtp-user
# Secret: dev-smtp-password

# ── Secret Manager Secrets Required (must be populated before first deploy) ───
# Run the following to populate each secret (replace <VALUE> with real value):
#
#   echo -n '<VALUE>' | gcloud secrets versions add dev-postgres-password --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add dev-secret-key --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add dev-first-superuser-password --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add dev-smtp-user --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add dev-smtp-password --data-file=-
#
# Also set the postgres user password on the SQL instance:
#   gcloud sql users set-password postgres \
#     --instance=voltech-sql-dev-<SUFFIX> \
#     --password=<VALUE> \
#     --project=voltechai
