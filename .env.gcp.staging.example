# =============================================================================
# GCP STAGING Environment Reference — voltech.ai
# =============================================================================
# This file documents the environment variables and secrets needed when the
# app runs on GCP Cloud Run (staging environment).
#
# ❌ Do NOT commit real values. Secrets go in Google Secret Manager.
# =============================================================================

# ── GCP Infra ────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=voltechai
GCP_REGION=asia-southeast1

# ── Cloud Run Service Names ───────────────────────────────────────────────────
BACKEND_SERVICE=staging-backend
LANDING_SERVICE=staging-landing
IMPACTMAKER_SERVICE=staging-impactmaker
CHANGEMAKER_SERVICE=staging-changemaker
VERIFIER_SERVICE=staging-verifier
GOV_SERVICE=staging-gov
PARTNER_SERVICE=staging-partner
ADMIN_SERVICE=staging-admin

# ── Artifact Registry ─────────────────────────────────────────────────────────
# Images are pushed to:
#   asia-southeast1-docker.pkg.dev/voltechai/app-services-staging/<image>:<sha>

# ── Cloud SQL ─────────────────────────────────────────────────────────────────
CLOUD_SQL_CONNECTION_NAME=voltechai:asia-southeast1:voltech-sql-staging-<SUFFIX>
POSTGRES_DB=app_staging
POSTGRES_USER=postgres
# Secret: staging-postgres-password

# ── Cloud Storage (GCS via ADC) ───────────────────────────────────────────────
BUCKET_NAME=voltech-storage-staging-<SUFFIX>
# ✅ No credentials needed — backend-sa-staging uses ADC automatically on Cloud Run.

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=staging
PROJECT_NAME=voltech.ai
# Secret: staging-secret-key
# Secret: staging-first-superuser-password

FIRST_SUPERUSER=admin@voltech.ai

# ── URLs ─────────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.voltech.demoebt.com
BACKEND_URL=https://api.voltech.demoebt.com
LANDING_URL=https://voltech.demoebt.com
IMPACTMAKER_URL=https://impactmaker.voltech.demoebt.com
CHAANGEMAKER_URL=https://changemaker.voltech.demoebt.com
VERIFIER_URL=https://verifier.voltech.demoebt.com
GOV_URL=https://gov.voltech.demoebt.com
PARTNER_URL=https://partner.voltech.demoebt.com
ADMIN_URL=https://admin.voltech.demoebt.com

# ── Email ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_TLS=true
EMAILS_FROM_EMAIL=noreply@voltech.demoebt.com
# Secret: staging-smtp-user
# Secret: staging-smtp-password

# ── Secret Manager Secrets Required ──────────────────────────────────────────
#   echo -n '<VALUE>' | gcloud secrets versions add staging-postgres-password --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add staging-secret-key --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add staging-first-superuser-password --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add staging-smtp-user --data-file=-
#   echo -n '<VALUE>' | gcloud secrets versions add staging-smtp-password --data-file=-
#
#   gcloud sql users set-password postgres \
#     --instance=voltech-sql-staging-<SUFFIX> \
#     --password=<VALUE> \
#     --project=voltechai
