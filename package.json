{
  "name": "fastapi-full-stack-template",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --filter frontend dev",
    "tsc": "bun run --filter frontend tsc",
    "format": "bun run --filter frontend format",
    "format:check": "bun run --filter frontend format:check",
    "format:fix": "bun run --filter frontend format:fix",
    "imports:sort": "bun run --filter frontend imports:sort",
    "lint": "bun run --filter frontend lint",
    "lint:fix": "bun run --filter frontend lint:fix",
    "generate-client": "bun run --filter frontend generate-client",
    "test": "bun run --filter frontend test",
    "test:ui": "bun run --filter frontend test:ui"
  }
}
